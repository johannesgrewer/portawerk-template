# [FIRMENNAME] — Environment Variables
# Kopiere diese Datei zu .env und fülle die Werte aus

# Analytics (Umami, self-hosted)
UMAMI_WEBSITE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Supabase (Backend + Dateispeicher)
SUPABASE_URL=https://dein-projekt.supabase.co
SUPABASE_ANON_KEY=dein-anon-key
SUPABASE_SERVICE_ROLE_KEY=dein-service-role-key

# Resend (E-Mail-Versand)
RESEND_API_KEY=re_xxxxxxxxxx
RESEND_FROM_EMAIL=info@[domain].de

# Kontaktformular Empfänger
CONTACT_RECIPIENT=info@[domain].de
